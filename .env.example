# 官方云：https://api.dify.ai/v1 （自建请改域名）
DIFY_API_URL=https://api.dify.ai/v1

# 端口（可选）
PORT=3000

# ---- 多智能体 API 密钥（在 Dify 分别为每个「聊天助手」创建应用并复制密钥）----
# ESFP：优先读 DIFY_API_KEY_ESFP；未设置时回落到 DIFY_API_KEY（兼容旧配置）
DIFY_API_KEY_ESFP=
DIFY_API_KEY=

# ISFJ（及其它性格在 server.js 的 AGENT_REGISTRY 里注册后再加一项 + 环境变量）
DIFY_API_KEY_ISFJ=

# 流式：qwen3.5-plus 等勿设 blocking
# DIFY_RESPONSE_MODE=blocking
